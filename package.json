{
  "name": "@thebigredgeek/spotify-mcp-server",
  "version": "1.0.0",
  "description": "Production-ready MCP server for Spotify control with bulletproof error handling",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "spotify-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "auth": "node dist/scripts/authenticate.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "spotify",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "music"
  ],
  "author": "Andrew Rhyne <andrew.rhyne@shopify.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebigredgeek/spotify-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "open": "^10.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.8",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
